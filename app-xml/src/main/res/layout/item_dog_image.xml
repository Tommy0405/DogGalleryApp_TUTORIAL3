<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout para cada item do grid principal.
    Cada imagem é apresentada dentro de um CardView para um aspeto moderno e consistente.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <!-- ImageView que exibe a imagem do cão com scaleType centerCrop -->
    <ImageView
        android:id="@+id/dogImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

</androidx.cardview.widget.CardView>